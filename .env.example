# Copy to .env and fill in values. .env is gitignored.

# Phoenix
# PHX_HOST=exhs.dk
# PHX_SERVER=true
# PORT=4000
# SECRET_KEY_BASE=
# TOKEN_SIGNING_SECRET=

# Database (prod only — dev/test default to localhost via config/dev.exs)
# DATABASE_URL=ecto://postgres:postgres@localhost:5432/exhs_dev
# POOL_SIZE=10

# Stripe (test mode keys in dev)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SIGNING_SECRET=whsec_...

# S3 / Minio
# In dev, defaults in config/dev.exs point at local Minio. Override here if needed.
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# AWS_REGION=eu-central-1
# S3_ENDPOINT=localhost
# S3_SCHEME=http://
# S3_PORT=9000
# S3_BUCKET=exhs-dev

# DNS cluster (prod)
# DNS_CLUSTER_QUERY=
