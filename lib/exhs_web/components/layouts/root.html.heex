<!DOCTYPE html>
<html lang="en">
  <head>
    {Application.get_env(:live_debugger, :live_debugger_tags)}

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Exhs" suffix=" · Exhs" phx-no-format>{assigns[:page_title]}</.live_title>
    <meta :if={assigns[:page_description]} name="description" content={@page_description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={assigns[:page_title] || "Exhs"} />
    <meta :if={assigns[:page_description]} property="og:description" content={@page_description} />
    <meta :if={assigns[:page_image]} property="og:image" content={@page_image} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>
    <script>
      (() => {
        // Theme preference is stored in a cookie scoped to the parent domain so
        // it is shared across the landing page and every forening subdomain
        // (localStorage is per-origin and would not carry across subdomains).
        const COOKIE = "theme";

        const parentDomain = () => {
          const labels = location.hostname.split(".");
          // Use the registrable parent (last two labels) so *.localhost and
          // *.exhs.dk share one cookie. Single-label hosts use themselves.
          return labels.length <= 1 ? location.hostname : labels.slice(-2).join(".");
        };

        const readPref = () => {
          const m = document.cookie.match(/(?:^|;\s*)theme=([^;]+)/);
          return m ? decodeURIComponent(m[1]) : "system";
        };

        const writePref = (theme) => {
          const maxAge = 60 * 60 * 24 * 365;
          document.cookie =
            `${COOKIE}=${encodeURIComponent(theme)};path=/;max-age=${maxAge};domain=${parentDomain()};SameSite=Lax`;
        };

        const prefersDark = () =>
          window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches;

        const apply = (theme) => {
          const resolved = theme === "system" ? (prefersDark() ? "dark" : "light") : theme;
          document.documentElement.setAttribute("data-theme", resolved);
          // Raw preference (incl. "system") drives the toggle's active highlight.
          document.documentElement.setAttribute("data-theme-pref", theme);
        };

        const setTheme = (theme) => {
          writePref(theme);
          apply(theme);
        };

        apply(readPref());

        if (window.matchMedia) {
          window
            .matchMedia("(prefers-color-scheme: dark)")
            .addEventListener("change", () => readPref() === "system" && apply("system"));
        }

        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body>
    {@inner_content}

    <div
      id="cookie-consent"
      hidden
      class="fixed inset-x-0 bottom-0 z-100 p-4"
    >
      <div class="bg-base-100 border-base-content/10 mx-auto flex max-w-3xl flex-col items-center gap-4 rounded-2xl border p-4 shadow-lg sm:flex-row sm:gap-6 sm:p-5">
        <p class="text-base-content/70 text-sm">
          {gettext(
            "We use cookies to improve your experience. You can choose which cookies you accept."
          )}
        </p>
        <div class="flex shrink-0 gap-2">
          <button data-consent-reject class="btn btn-ghost btn-sm">
            {gettext("Only necessary")}
          </button>
          <button data-consent-accept class="btn btn-primary btn-sm">
            {gettext("Accept all")}
          </button>
        </div>
      </div>
    </div>
  </body>
</html>
